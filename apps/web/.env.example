# Frontend (apps/web) — copy to apps/web/.env
# Where the server-side proxy (hooks.server.ts) forwards /api and /health.
API_URL=http://localhost:9001
# Dashboard password(s), comma-separated. Leave blank to disable the login gate.
# NOTE: set this (here for `bun run dev`, or root .env for docker compose) or the
# app stays open with no login prompt.
AUTH_PASSWORD=
# Optional: HMAC secret for the auth cookie (defaults to a value derived from the
# password). Set a random string in production.
AUTH_SECRET=
# Must MATCH apps/api/.env's API_TOKEN (injected into /api calls by the proxy).
API_TOKEN=
