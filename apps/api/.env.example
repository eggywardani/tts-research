# Backend API (apps/api) — copy to apps/api/.env
PORT=9001
# URL of the Python TTS service. Use the GPU host if remote.
TTS_URL=http://localhost:9000
# Optional: require this token (header x-api-token) on /api/*. Leave blank to
# disable. Must MATCH apps/web/.env's API_TOKEN so the web proxy can inject it.
API_TOKEN=

# Optional S3 archival of generated audio. When S3_BUCKET + AWS creds are all
# set, /api/speak uploads the wav to s3://$S3_BUCKET/outputs/{uuid}.wav and
# returns a presigned URL instead of the bytes. Leave blank to keep audio inline.
S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
