# Backend API (apps/api) — copy to apps/api/.env
PORT=9001
# URL of the Python TTS service. Use the GPU host if remote.
TTS_URL=http://localhost:9000
# Optional: require this token (header x-api-token) on /api/*. Leave blank to
# disable. Must MATCH apps/web/.env's API_TOKEN so the web proxy can inject it.
API_TOKEN=
