# Root .env — used ONLY by docker-compose for ${VAR} substitution.
# For running services directly (bun run dev / python main.py), each app reads
# its OWN env: see apps/api/.env.example, apps/web/.env.example, apps/tts/.env.example.

# Dashboard password(s), comma-separated. Blank = login gate disabled.
AUTH_PASSWORD=
# HMAC secret for the auth cookie. Set a random string in production.
AUTH_SECRET=
# Shared backend token. Injected into /api calls by the web proxy; the API
# rejects /api/* without it. Set on both api + web (compose wires both). Blank = off.
API_TOKEN=
# Cloudflare Tunnel token (Zero Trust → Networks → Tunnels). Exposes the stack
# publicly with no inbound port. Blank / omit the tunnel service to run local-only.
TUNNEL_TOKEN=

# Postgres password (speakers + history + jobs). DATABASE_URL is wired into the
# api service by compose using this value. Defaults to "tts" if blank.
POSTGRES_PASSWORD=tts
# Worker-pool size (parallel TTS jobs). Match GPU capacity; 1 per GPU.
TTS_CONCURRENCY=1

# Optional S3 archival of generated audio (wired into the api service). When all
# are set, /api/speak uploads the wav to s3://$S3_BUCKET/outputs/{uuid}.wav and
# returns a presigned URL instead of the bytes. Blank = keep audio inline.
S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
